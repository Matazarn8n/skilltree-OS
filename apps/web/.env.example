# SkillTree-OS — variables d'environnement (copier vers .env.local, git-ignoré).
# Supabase LOCAL en dev : `npx supabase start` puis `npx supabase status -o json` fournit URL + clés.

# API Supabase (local: http://127.0.0.1:54321)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
# Clé anon (publique, exposée au client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service-role — SERVER-ONLY, ne JAMAIS préfixer NEXT_PUBLIC_ ni exposer au navigateur
SUPABASE_SERVICE_ROLE_KEY=

# D8 : mode perso mono-tenant. "true" force paid=true (/api/access) — Stripe non exercé.
PERSONAL_MODE=true

# Gateway HERMES (D7) : l'app relaie l'OAuth via X-Internal-Token UNIQUEMENT.
# JAMAIS de clé Anthropic (x-api-key / ANTHROPIC_API_KEY / sk-ant / Bearer) dans l'app.
HERMES_GATEWAY_URL=http://localhost:8765
HERMES_INTERNAL_TOKEN=

# Stripe (EXT-02, non exercé en perso). Absent → /api/stripe/webhook répond 501.
STRIPE_WEBHOOK_SECRET=
